# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cairn

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
PORT=3001

# Benchmark anonymisation salt (keep secret, rotate with care)
BENCHMARK_SALT=change-me-in-production

# Set to 'true' to run cairn_public schema initialisation on startup
DB_INIT_ON_START=false
