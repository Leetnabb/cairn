# Cairn frontend environment variables (Vite).
# Copy to .env.local for local development. All VITE_* vars are exposed to the client.

# Supabase project (required for auth, AI edge functions and workspace sync).
# Without these the app runs in local-only mode (localStorage), and auth/AI/sync are disabled.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Kill-switch for Supabase workspace sync. Set to "true" to disable cross-device
# sync and fall back to localStorage-only (useful while validating sync in prod).
VITE_DISABLE_SUPABASE_SYNC=

# --- Supabase edge function secrets (set via `supabase secrets set`, NOT here) ---
# ANTHROPIC_API_KEY   Anthropic API key used by the AI proxy functions.
# ALLOWED_ORIGINS     Comma-separated CORS allow-list, e.g.
#                     https://www.cairnpath.io,https://cairnpath.io,http://localhost:5173
#                     Defaults to those three if unset.
